[global]
    offset = (5,5)
    origin = top-right

    font = "Hack Nerd Font Mono 10"
    frame_color = "#3584e4"
    gap_size = 5

[urgency_low]
    background = "#1e1e1e"
    foreground = "#ffffff"
    timeout = 1.5

[urgency_normal]
    background = "#1e1e1e"
    foreground = "#ffffff"
    timeout = 3

[urgency_critical]
    background = "#e01b24"
    foreground = "#ffffff"
    frame_color = "#1e1e1e"
    timeout = 0
